<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} · {% endif %}dankwx</title>
    <style>
      body {
        font-family: "Courier New", "Courier", monospace;
        background-color: #c5d8e8;
        background-image:
          repeating-linear-gradient(45deg, rgba(255,255,255,0.25) 0 2px, transparent 2px 14px);
        color: #1a1a2e;
        font-size: 16px;
        line-height: 1.55;
        margin: 0;
        padding: 1.5rem 0.75rem 3rem;
      }
      .window {
        max-width: 40rem;
        margin: 0 auto;
        background: #fdfdf6;
      }
      nav {
        border-top: 2px solid #1a1a2e;
        border-bottom: 2px solid #1a1a2e;
        background: #e8e3cf;
        padding: 0.4rem 0.8rem;
        font-size: 0.95rem;
      }
      nav a { margin-right: 0.6rem; }
      main { padding: 1.2rem 1.4rem; }
      a { color: #0000cc; }
      a:visited { color: #660099; }
      a:hover { background: #ffff66; }
      h1 { font-size: 1.5rem; border-bottom: 2px dashed #1a1a2e; padding-bottom: 0.3rem; }
      h2 { font-size: 1.2rem; }
      time { color: #555; font-size: 0.85rem; }
      hr { border: none; border-top: 2px dashed #1a1a2e; margin: 1.5rem 0; }
      ul.posts { list-style: none; padding: 0; }
      ul.posts li { margin: 0.4rem 0; }
      ul.posts li::before { content: "» "; color: #cc0000; }
      ul.posts time { margin-right: 0.5rem; }
      pre, code { background: #e8e3cf; }
      pre { padding: 0.8rem; overflow-x: auto; border: 1px solid #1a1a2e; }
      code { padding: 0.05rem 0.25rem; }
      blockquote {
        border-left: 4px solid #cc0000;
        margin-left: 0;
        padding-left: 1rem;
        color: #444;
      }
      img { max-width: 100%; height: auto; }
      .home-img {
        display: block;
        margin: 0 auto 1rem;
        border: 3px double #1a1a2e;
        padding: 4px;
        background: #fff;
      }
      footer {
        border-top: 2px solid #1a1a2e;
        background: #e8e3cf;
        padding: 0.5rem 0.8rem;
        font-size: 0.8rem;
        text-align: center;
        color: #555;
      }
    </style>
  </head>
  <body>
    <div class="window">
      <nav>
        <a href="/">[ home ]</a>
        <a href="/">[ posts ]</a>
      </nav>
      <main>
        {{ content | safe }}
      </main>
      <footer>
        ✧ feito no Obsidian, gerado com Eleventy ✧ {{ "now" | date }}
      </footer>
    </div>
  </body>
</html>
