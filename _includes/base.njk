<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>{% if title %}{{ title }} · {% endif %}dankwx</title>
    <style>
      :root {
        --bg: #0d0d0f;
        --panel: #131318;
        --text: #c8c8c8;
        --dim: #6f6f78;
        --head: #f1f0ea;
        --accent: #6ee7a8;
        --accent2: #ff6ec7;
        --border: #2a2a31;
        --serif: Georgia, "Times New Roman", "Noto Serif", serif;
        --mono: Consolas, "Cascadia Mono", "Cascadia Code", ui-monospace,
          "DejaVu Sans Mono", "SFMono-Regular", Menlo, "Liberation Mono",
          monospace;
      }
      html { background: var(--bg); }
      body {
        font-family: var(--mono);
        background-color: var(--bg);
        /* scanlines + leve textura vertical (estática, sem JS) */
        background-image:
          repeating-linear-gradient(0deg, rgba(255,255,255,0.025) 0 1px, transparent 1px 3px),
          repeating-linear-gradient(90deg, rgba(255,255,255,0.015) 0 1px, transparent 1px 40px);
        color: var(--text);
        font-size: 16.5px;
        line-height: 1.7;
        letter-spacing: 0.01em;
        margin: 0;
        padding: 1.5rem 0.75rem 3rem;
      }
      .window {
        max-width: 42rem;
        margin: 0 auto;
        background: var(--panel);
        border: 1px solid var(--border);
      }
      nav {
        border-bottom: 1px solid var(--border);
        padding: 0.5rem 0.9rem;
        font-size: 0.9rem;
        letter-spacing: 0.05em;
        color: var(--dim);
      }
      nav a { margin-right: 0.8rem; }
      main { padding: 1.4rem 1.5rem; }

      a {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      a:visited { color: #9bbfae; }
      a:hover { color: var(--accent2); background: rgba(255,110,199,0.08); }

      h1, h2, h3 { font-family: var(--serif); color: var(--head); font-weight: 600; line-height: 1.1; }
      h1 { font-size: 2.6rem; letter-spacing: -0.01em; margin: 0.2rem 0 0.6rem; }
      h2 { font-size: 1.6rem; margin-top: 2rem; }
      h3 { font-size: 1.2rem; }
      main > p, article p { max-width: 40rem; }

      time, .meta { color: var(--dim); font-size: 0.85rem; }
      .meta { margin: 0.2rem 0 0.6rem; letter-spacing: 0.03em; }
      .edited { color: var(--dim); font-size: 0.8rem; }

      .tags { margin: 0.3rem 0 1.2rem; }
      .tag {
        display: inline-block;
        color: var(--accent);
        border: 1px solid var(--border);
        background: #1a1a20;
        padding: 0 0.45rem;
        font-size: 0.78rem;
        margin-right: 0.3rem;
        text-transform: lowercase;
      }

      hr { border: none; border-top: 1px solid var(--border); margin: 1.6rem 0; }

      ul.posts { list-style: none; padding: 0; }
      ul.posts li { margin: 0.45rem 0; }
      ul.posts li::before { content: ">> "; color: var(--accent); }
      ul.posts time { margin-right: 0.6rem; color: var(--dim); }

      pre, code { background: #0a0a0c; color: #d6d6d6; }
      pre { padding: 0.9rem; overflow-x: auto; border: 1px solid var(--border); }
      code { padding: 0.05rem 0.3rem; border: 1px solid var(--border); }
      pre code { border: none; padding: 0; }

      blockquote {
        border-left: 3px solid var(--accent);
        margin-left: 0;
        padding-left: 1rem;
        color: var(--dim);
      }

      img { max-width: 100%; height: auto; }
      .home-img {
        display: block;
        margin: 0 auto 1.4rem;
        border: 1px solid var(--border);
        filter: grayscale(0.15) contrast(1.05);
      }

      footer {
        border-top: 1px solid var(--border);
        padding: 0.6rem 0.9rem;
        font-size: 0.78rem;
        color: var(--dim);
        letter-spacing: 0.03em;
      }
    </style>
  </head>
  <body>
    <div class="window">
      <nav>
        <a href="/">~/home</a>
        <a href="/posts/">~/posts</a>
      </nav>
      <main>
        {{ content | safe }}
      </main>
      <footer>
        // feito no Obsidian, gerado com Eleventy &middot; {{ "now" | date }}
      </footer>
    </div>
  </body>
</html>
