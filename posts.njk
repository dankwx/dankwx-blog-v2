layout: base.njk
title: "posts"
permalink: /posts/
---
<h1>posts</h1>

<p class="meta">&gt; tudo que já foi publicado</p>

<ul class="posts">
  {%- for post in collections.post | reverse %}
  <li>
    <time>{{ post.date | date }}</time>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
  </li>
  {%- endfor %}
</ul>
